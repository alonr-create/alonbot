<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alonbot-tunnel</string>
    <key>ProgramArguments</key>
    <array>
        <!-- EDIT THIS: path to start-tunnel.sh in your project -->
        <string>/PATH/TO/alonbot/scripts/start-tunnel.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>60</integer>
    <key>EnvironmentVariables</key>
    <dict>
        <!-- EDIT THIS: your Render cloud URL -->
        <key>ALONBOT_CLOUD_URL</key>
        <string>https://YOUR-APP.onrender.com</string>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/alonbot-tunnel.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/alonbot-tunnel.log</string>
</dict>
</plist>
