<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alonbot-tunnel</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/oakhome/קלוד עבודות/alonbot/scripts/keep-tunnel-alive.sh</string>
