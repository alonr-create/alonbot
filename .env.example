# AalonBot — Environment Variables
# Copy this to .env and fill in your values

# ── Required ──
ANTHROPIC_API_KEY=sk-ant-...
ALON_PHONE=972XXXXXXXXX

# ── Monday.com ──
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_BOARD_ID_DPRISHA=
MONDAY_STATUS_COLUMN_ID=status

# ── Facebook Marketing API ──
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN_ALON=

# ── Google Calendar (Apps Script proxy URL) ──
GOOGLE_CALENDAR_SCRIPT_URL=

# ── Voice ──
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Telegram (escalation alerts) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Server ──
PORT=3000
DATA_DIR=./data
NODE_ENV=development
