# AlonBot Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === REQUIRED ===

# AI — Claude API (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=123456789:AABBC-YOUR_TOKEN_HERE

# Security — comma-separated Telegram user IDs that can interact with the bot
# Find your ID: message @userinfobot on Telegram
ALLOWED_TELEGRAM=123456789

# === OPTIONAL (enable extra features) ===

# Gemini API — image generation, web research, vision, fallback model
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Monday.com API — business board queries
# https://monday.com/developers
MONDAY_API_KEY=

# ElevenLabs — text-to-speech voice messages
# https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Groq — free Whisper STT for voice message transcription
# https://console.groq.com/
GROQ_API_KEY=

# Gmail — send emails (requires App Password, not regular password)
# https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# WhatsApp — comma-separated phone numbers (972XXXXXXXXX format)
ALLOWED_WHATSAPP=

# === DEPLOYMENT ===

# Mode: 'cloud' = full bot (Telegram polling + cron), 'local' = cron only (send-only, no polling)
MODE=cloud

# Server port
PORT=3700

# Cloud-Local bridge (for running both cloud + local Mac)
LOCAL_API_SECRET=change-me-to-something-random
# LOCAL_API_URL is set automatically when Mac registers via tunnel
